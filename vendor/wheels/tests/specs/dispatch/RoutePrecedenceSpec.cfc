component extends="wheels.WheelsTest" {

	function beforeAll() {
		_originalRoutes = Duplicate(application.wheels.routes)
		_originalStaticRoutes = StructKeyExists(application.wheels, "staticRoutes") ? StructCopy(application.wheels.staticRoutes) : {}
		_originalNamedRoutePositions = StructKeyExists(application.wheels, "namedRoutePositions") ? StructCopy(application.wheels.namedRoutePositions) : {}
		application.wheels.routes = []
		application.wheels.staticRoutes = {}
		application.wheels.namedRoutePositions = {}

		// Deliberately "mis-ordered" route table: the placeholder routes generated by
		// .resources("posts") are declared BEFORE the literal /posts/featured. Under pure
		// first-match-wins the show route (/posts/[key]) would steal /posts/featured; the
		// static-route index makes the literal win regardless of declaration order.
		// These are the intended two-tier semantics — see issue 3073.
		application.wo.mapper()
			.resources("posts")
			.get(name = "featuredPosts", pattern = "/posts/featured", to = "posts##featured")
			.get(name = "teamPage", pattern = "/about/team", to = "pages##team")
			.get(name = "aboutPage", pattern = "/about/[page]", to = "pages##show")
			.get(name = "dupFirst", pattern = "/dup", to = "pages##firstdup")
			.get(name = "dupSecond", pattern = "/dup", to = "pages##seconddup")
			.get(name = "thingsFirst", pattern = "/things/[key]", to = "things##first")
			.get(name = "thingsSecond", pattern = "/things/[slug]", to = "things##second")
			.end()

		d = application.wo.$createObjectFromRoot(path = "wheels", fileName = "Dispatch", method = "$init")
	}

	function afterAll() {
		application.wheels.routes = _originalRoutes
		application.wheels.staticRoutes = _originalStaticRoutes
		application.wheels.namedRoutePositions = _originalNamedRoutePositions
	}

	function run() {
		describe("Route precedence: static index first, then ordered scan (issue 3073)", () => {

			beforeEach(() => {
				_originalCgiMethod = request.cgi.request_method
				request.cgi["request_method"] = "GET"
			})

			afterEach(() => {
				request.cgi["request_method"] = _originalCgiMethod
			})

			it("resolves a literal path to the static route even when it is declared AFTER a matching placeholder route", () => {
				route = d.$findMatchingRoute(path = "posts/featured")
				expect(route.controller).toBe("posts")
				expect(route.action).toBe("featured")
			})

			it("still resolves dynamic segments through the placeholder route", () => {
				route = d.$findMatchingRoute(path = "posts/42")
				expect(route.controller).toBe("posts")
				expect(route.action).toBe("show")
			})

			it("resolves a literal path to the static route when it is declared BEFORE a matching placeholder route", () => {
				route = d.$findMatchingRoute(path = "about/team")
				expect(route.action).toBe("team")
			})

			it("uses declaration order to break ties between identical static patterns", () => {
				route = d.$findMatchingRoute(path = "dup")
				expect(route.action).toBe("firstdup")
			})

			it("uses declaration order to decide placeholder-vs-placeholder conflicts", () => {
				route = d.$findMatchingRoute(path = "things/abc")
				expect(route.action).toBe("first")
			})

			it("scopes the static index by HTTP method so a GET literal does not shadow other verbs", () => {
				request.cgi["request_method"] = "DELETE"
				route = d.$findMatchingRoute(path = "posts/featured")
				expect(route.action).toBe("delete")
			})
		})
	}
}
