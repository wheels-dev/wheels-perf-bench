# IDE and editor files
.project
.settings
.classpath
.idea/
.vscode/
*.swp
*.swo

# CFML engine artifacts
.CommandBox
CFIDE
cfide
WEB-INF
**/cfclasses/

# Build and temp
/target/
/temp/
/bin/

# Generated server scaffolding (per-machine)
rewrite.config

# Server state
settings.json
settings.xml
.wheels/

# Environment files (contain generated secrets — never commit)
.env
.env.*
!.env.example

# Transient SQLite sidecar files. The seeded db/*.sqlite fixtures ARE committed
# on purpose (see db/.gitignore) so the benchmark runs on any engine with no
# migration step.
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Test output
/test-output/
/test-artifacts/

# OS files
.DS_Store
Thumbs.db

# NOTE: /vendor/ is intentionally NOT ignored. This is a self-contained
# benchmark repo — the Wheels framework is committed so you can clone and run
# on any engine (including RustCFML) without an install step.
