# Copy to .env and fill in if you want them. The benchmark workload runs WITHOUT
# any of these — they only enable the dev reload endpoint and the Lucee admin,
# and are per-machine, not secrets that gate the app.
#
#   cp .env.example .env
#
WHEELS_ENV=development
WHEELS_DATASOURCE=benchdb
WHEELS_RELOAD_PASSWORD=change-me-if-you-want-reload
WHEELS_LUCEE_ADMIN_PASSWORD=change-me-if-you-want-lucee-admin
